# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/mefa_cafe
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mefa_cafe?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe Configuration (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@mefacafe.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin Credentials
ADMIN_EMAIL=admin@mefacafe.com
ADMIN_PASSWORD=admin123

# Delivery Charges
DELIVERY_CHARGE=50
FREE_DELIVERY_ABOVE=500
